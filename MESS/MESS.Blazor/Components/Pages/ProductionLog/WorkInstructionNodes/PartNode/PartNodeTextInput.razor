@using MESS.Data.Models
@using MESS.Services.UI.PartTraceability
@inject IPartTraceabilityStateService PartTraceabilityService

<div class="form-floating flex-grow-1">
    @switch (PartNode.InputType)
    {
        case PartInputType.SerialNumber:
            <InputText
                id="serialInput"
                class="form-control tall-input text-lightweight"
                placeholder="@PartNode.PartDefinition!.Number"
                @bind-Value="_serialNumber"
                @bind-Value:after="OnInputChanged" />

            <label for="serialInput" class="form-label subtle-label">
                @(PartNode.PartDefinition!.Name)
            </label>
            break;

        case PartInputType.Tag:
            <InputText
                id="tagInput"
                class="form-control tall-input text-lightweight"
                placeholder="Enter tag code"
                @bind-Value="_tagCode"
                @bind-Value:after="OnInputChanged" />

            <label for="tagInput" class="form-label subtle-label">
                Tag Code
            </label>
            break;

        default:
            throw new ArgumentOutOfRangeException();
    }

    @if (_isSearching)
    {
        <div class="form-text text-muted small">Searching...</div>
    }

    @if (_validationMessage is not null)
    {
        <div class="form-text @( _validationMessageType == ValidationMessageType.Success ? "text-success" : "text-danger") small">
            @_validationMessage
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required PartNode PartNode { get; set; }
    [Parameter, EditorRequired] public int LogIndex { get; set; }
    [Parameter] public EventCallback<(PartNode node, object? value)> AfterInputChanged { get; set; }

    private string? _serialNumber;
    private string? _tagCode;
    private bool _isSearching;
    private string? _validationMessage;
    private ValidationMessageType _validationMessageType;
    private CancellationTokenSource? _debounceCts;

    private enum ValidationMessageType { Success, Error }

    protected override void OnParametersSet()
    {
        var entry = PartTraceabilityService.AddOrGetEntry(LogIndex, PartNode.Id);
        _serialNumber = entry.SerialNumber;
        _tagCode = entry.TagCode;
    }

    private async Task OnInputChanged()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, _debounceCts.Token); // debounce
        }
        catch (TaskCanceledException)
        {
            return;
        }

        _isSearching = true;
        StateHasChanged();

        string? updatedValue = null;

        switch (PartNode.InputType)
        {
            case PartInputType.SerialNumber:
                updatedValue = string.IsNullOrWhiteSpace(_serialNumber) ? null : _serialNumber;
                PartTraceabilityService.UpdateSerialNumber(LogIndex, PartNode.Id, updatedValue);
                break;

            case PartInputType.Tag:
                updatedValue = string.IsNullOrWhiteSpace(_tagCode) ? null : _tagCode;
                var resolved = await PartTraceabilityService.UpdateTagCodeAsync(LogIndex, PartNode.Id, updatedValue);
                _validationMessage = string.IsNullOrWhiteSpace(_tagCode)
                    ? null
                    : resolved ? "Tag available" : "No part found";
                _validationMessageType = resolved ? ValidationMessageType.Success : ValidationMessageType.Error;
                break;

            default:
                throw new ArgumentOutOfRangeException();
        }

        _isSearching = false;
        StateHasChanged();

        if (AfterInputChanged.HasDelegate)
            await AfterInputChanged.InvokeAsync((PartNode, updatedValue));
    }
}