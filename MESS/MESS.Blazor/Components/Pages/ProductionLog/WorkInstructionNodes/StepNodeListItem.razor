@using System.Text.RegularExpressions
@using MESS.Data.Models
@using MESS.Services.ProductionLog
@using MESS.Blazor.Components.Carousel
@using MESS.Blazor.Components.Pages.ProductionLog
@using Microsoft.AspNetCore.Components.Authorization
@inject IProductionLogEventService ProductionLogEventService
@inject IJSRuntime JsRuntime
@inject AuthenticationStateProvider AuthProvider

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col col-md-6 col-sm-12 d-flex flex-column primary-content">
                <div class="card">
                    <div class="card-body">
                        <p class="card-text d-block mb-1" style="white-space: pre-wrap;">
                            @switch (ShowDetails)
                            {
                                case false:
                                    @((MarkupString)Step.Body)
                                    break;
                                case true when Step.DetailedBody != null:
                                    @((MarkupString)Step.DetailedBody)
                                    break;
                            }
                        </p>
                    </div>
                </div>

                <div class="mt-auto">
                    @if (ShowRedTag)
                    {
                        <RedTagDialog
                            OperatorName="@OperatorName"
                            ProductName="@SelectedProduct?.PartName"
                            WorkInstruction="@StepWorkInstruction"
                            WorkInstructionName="@WorkInstructionName"
                            StepDescription="@StepDescription"
                            StepAttemptId="@StepAttemptId"
                            FailureNoteText="@FailureNoteText"
                            SelectedProductId="@SelectedProductIdForDialog"
                            OnCancel="@CancelRedTag"
                            OnSubmit="@ConfirmRedTag" />
                    }

                    <div class="position-relative w-100 mt-3 @(ShowOptionalNotesField ? "" : "d-none")" style="display: flex; align-items: flex-start; gap: 8px;">
                        <FluentTextArea 
                            @ref="_failureNoteTextArea" 
                            data-testid="optional-notes" 
                            class="flex-grow-1"
                            placeholder="Optional: Add a failure note (if needed)"
                            @bind-Value="_currentAttemptNotes"
                            @bind-Value:after="@(async () => await HandleNoteChangedAsync())" />

                        <button type="button"
                                class="btn btn-outline-warning btn-sm"
                                style="height: fit-content; align-self: flex-start;"
                                title="Show Red Tag Form"
                                @onclick="ShowRedTagForm">
                            Red Tag
                        </button>
                    </div>

                    <div class="row mt-2">
                        <div class="col text-start">
                            <div class="position-relative d-inline-block">
                                <input type="radio"
                                       class="btn-check"
                                       name="statusToggle"
                                       id="radioSuccessBtn{@Step.Body}-@Step.Id"
                                       checked="@(SelectedButton == "Success")"
                                       @onclick="@(async (e) => await HandleButtonPress(true))"/>
                                <label class="btn btn-outline-success @(SelectedButton == "Success" ? "active" : "")"
                                       for="radioSuccessBtn{@Step.Body}-@Step.Id">
                                    Success
                                </label>
                                @if (_showSuccessFloat)
                                {
                                    <div class="floating-label" style="left: 50%; transform: translateX(-50%);">
                                        Success!
                                    </div>
                                }
                            </div>
                            <div class="position-relative d-inline-block">
                                <input type="radio"
                                       class="btn-check"
                                       name="statusToggle"
                                       id="radioFailureBtn{@Step.Body}-@Step.Id"
                                       checked="@(SelectedButton == "Failure")"
                                       @onclick="@(async (e) => await HandleButtonPress(false))"/>
                                <label class="btn btn-outline-danger @(SelectedButton == "Failure" ? "active" : "")"
                                       for="radioFailureBtn{@Step.Body}-@Step.Id">
                                    Failure
                                </label>
                                @if (_showFailureFloat)
                                {
                                    <div class="floating-label" style="left: 50%; transform: translateX(-50%); color: #dc3545;">
                                        Failure!
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col text-end">
                            @if (HasDetails)
                            {
                                <button @onclick="toggleDetails" class="btn btn-outline-secondary text-decoration-none" type="button">
                                    @(ShowDetails ? "Hide Details" : "Show Details")
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col col-md-6 secondary-content">
                @if (Step.PrimaryMedia.Count > 0 || Step.SecondaryMedia.Count > 0) 
                {
                    @if (ShowDetails)
                    {
                        if (Step.SecondaryMedia.Count > 0)
                        {
                            <Carousel Images="@Step.SecondaryMedia" AutoPlay="false" Interval="3000" ImageStyle="height: 500px; object-fit: contain;" />
                        }
                        else if (Step.PrimaryMedia.Count > 0)
                        {
                            <Carousel Images="@Step.PrimaryMedia" AutoPlay="false" Interval="3000" ImageStyle="height: 500px; object-fit: contain;" />
                        }
                    }
                    else if (Step.PrimaryMedia.Count > 0)
                    {
                        <Carousel Images="@Step.PrimaryMedia" AutoPlay="false" Interval="3000" ImageStyle="height: 500px; object-fit: contain;" />
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// The current <see cref="Step"/> being displayed.
    /// </summary>
    [Parameter]
    public required Step Step { get; set; }

    /// <summary>
    /// The corresponding <see cref="ProductionLogStep"/> for this step.
    /// </summary>
    [Parameter]
    public required ProductionLogStep LogStep { get; set; }

    /// <summary>
    /// List of all available <see cref="Part"/> items to select and display.
    /// </summary>
    [Parameter]
    public List<Part> AllParts { get; set; } = new();

    /// <summary>
    /// Optional list of all <see cref="WorkInstruction"/> items.
    /// </summary>
    [Parameter]
    public List<WorkInstruction>? AllWorkInstructions { get; set; }

    /// <summary>
    /// Currently selected part ID used in the RedTag dialog.
    /// </summary>
    [Parameter]
    public int? SelectedPartId { get; set; }
    
    /// <summary>
    /// Callback invoked when the step is completed with a success/failure result or red tag submission.
    /// </summary>
    [Parameter]
    public EventCallback<(ProductionLogStep, bool?)> OnStepCompleted { get; set; }
    
    /// <summary>
    /// Gets or sets the operator's display name used within the component.
    /// This can be set externally to personalize or identify the current operator context.
    /// </summary>
    private string OperatorName { get; set; } = "";
    
    /// <summary>
    /// Called by the framework when the component is initialized asynchronously.
    /// Loads the current operator name from the authentication state and sets up initial values.
    /// </summary>
    /// <returns>A task representing the asynchronous operation.</returns>
    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthProvider.GetAuthenticationStateAsync()).User;

        string firstName = user.Claims.FirstOrDefault(c => c.Type.Contains("givenname", StringComparison.OrdinalIgnoreCase))?.Value ?? "";
        string lastName = user.Claims.FirstOrDefault(c => c.Type.Contains("surname", StringComparison.OrdinalIgnoreCase))?.Value ?? "";

        if (string.IsNullOrWhiteSpace(firstName) && string.IsNullOrWhiteSpace(lastName))
        {
            OperatorName = user.Claims.FirstOrDefault(c => c.Type == "name")?.Value
                           ?? user.Identity?.Name
                           ?? "Unknown Operator";
        }
        else
        {
            OperatorName = $"{firstName} {lastName}".Trim();
        }

        Console.WriteLine($"[Debug] OperatorName set to: '{OperatorName}'");
        await InvokeAsync(StateHasChanged);
    }


    /// <summary>
    /// Gets the part ID from the <see cref="LogStep"/>.
    /// </summary>
    private int? StepPartId => null; // or replace null with the actual property if known

    /// <summary>
    /// Gets the WorkInstruction ID from the current <see cref="Step"/>.
    /// Currently returns null since your model does not have this property.
    /// </summary>
    private int? StepWorkInstructionId => null;

    /// <summary>
    /// The currently selected <see cref="Part"/> for the RedTag dialog.
    /// </summary>
    private Part? SelectedProduct => AllParts.FirstOrDefault(p => p.Id == (StepPartId ?? SelectedPartId));

    /// <summary>
    /// The ID of the selected product passed to the RedTag dialog.
    /// </summary>
    private int SelectedProductIdForDialog => SelectedProduct?.Id ?? -1;
    
    /// <summary>
    /// Updates the selected part ID when the user selects a different part.
    /// </summary>
    /// <param name="id">The ID of the newly selected part.</param>
    private void OnSelectedPartIdChanged(int? id)
    {
        SelectedPartId = id;
    }

    /// <summary>
    /// The name of the work instruction for display in the RedTag dialog.
    /// </summary>
    private string WorkInstructionName => StepWorkInstructionId.HasValue
        ? AllWorkInstructions?.FirstOrDefault(w => w.Id == StepWorkInstructionId.Value)?.Title
          ?? $"Work Instruction {StepWorkInstructionId.Value}"
        : "Unavailable";

    /// <summary>
    /// The plain-text description of the step, stripped from any HTML.
    /// </summary>
    private string StepDescription => Regex.Replace(Step.Body ?? "", "<.*?>", "").Trim();

    /// <summary>
    /// The ID string of the latest step attempt.
    /// </summary>
    private string StepAttemptId => LogStep.LatestAttempt?.Id.ToString() ?? "N/A";

    /// <summary>
    /// The failure note text from the latest attempt, if any.
    /// </summary>
    private string FailureNoteText => LogStep.LatestAttempt?.Notes ?? "";

    /// <summary>
    /// Flag indicating whether the RedTag dialog is currently shown.
    /// </summary>
    private bool ShowRedTag = false;

    /// <summary>
    /// Shows the RedTag dialog.
    /// </summary>
    private void ShowRedTagForm() => ShowRedTag = true;

    /// <summary>
    /// Cancels/hides the RedTag dialog.
    /// </summary>
    private void CancelRedTag() => ShowRedTag = false;

    /// <summary>
    /// Confirms the RedTag submission and updates the log step accordingly.
    /// </summary>
    private async Task ConfirmRedTag()
    {
        LogStep.IsRedTagged = true;
        ShowRedTag = false;
        await OnStepCompleted.InvokeAsync((LogStep, null));
    }

    /// <summary>
    /// Reference to the failure note <see cref="FluentTextArea"/> control.
    /// </summary>
    private FluentTextArea? _failureNoteTextArea;

    /// <summary>
    /// Current failure note text being edited.
    /// </summary>
    private string _currentAttemptNotes = "";

    /// <summary>
    /// The pending failure attempt being edited.
    /// </summary>
    private ProductionLogStepAttempt? _pendingFailureAttempt;

    /// <summary>
    /// Whether to show detailed step content.
    /// </summary>
    private bool ShowDetails = false;

    /// <summary>
    /// Toggles display of detailed step content.
    /// </summary>
    private void toggleDetails() => ShowDetails = !ShowDetails;

    /// <summary>
    /// Whether the optional failure notes field is shown.
    /// </summary>
    private bool ShowOptionalNotesField { get; set; } = false;

    /// <summary>
    /// Name of the currently selected status button ("Success", "Failure", or empty).
    /// </summary>
    private string? SelectedButton { get; set; } = "";

    /// <summary>
    /// Sets the currently selected button name.
    /// </summary>
    /// <param name="buttonName">The button name to set ("Success" or "Failure").</param>
    private void SetSelectedButton(string buttonName) => SelectedButton = buttonName;

    /// <summary>
    /// Sets up the optional notes field if there is existing failure note or failure state.
    /// </summary>
    private void SetOptionalNotes()
    {
        var attempt = LogStep.LatestAttempt;
        if (!string.IsNullOrWhiteSpace(attempt.Notes) || (attempt.Success.HasValue && !attempt.Success.Value))
        {
            _currentAttemptNotes = attempt.Notes;
            ShowOptionalNotesField = true;
        }
    }
    
    private WorkInstruction? StepWorkInstruction =>
        StepWorkInstructionId.HasValue
            ? AllWorkInstructions?.FirstOrDefault(w => w.Id == StepWorkInstructionId.Value)
            : null;

    /// <summary>
    /// Handles pressing the Success or Failure radio buttons, creating and saving an attempt accordingly.
    /// </summary>
    /// <param name="result">True for success, false for failure, null to clear selection.</param>
    private async Task HandleButtonPress(bool? result)
    {
        if (!result.HasValue)
        {
            ShowOptionalNotesField = false;
            _pendingFailureAttempt = null;
            _currentAttemptNotes = string.Empty;
            SetSelectedButton("");
            return;
        }

        if (result.Value)
        {
            var attempt = new ProductionLogStepAttempt
            {
                Success = true,
                SubmitTime = DateTimeOffset.UtcNow,
                Notes = ""
            };

            LogStep.Attempts.Add(attempt);
            _pendingFailureAttempt = null;
            _currentAttemptNotes = string.Empty;
            ShowOptionalNotesField = false;

            await OnStepCompleted.InvokeAsync((LogStep, true));
            SetSelectedButton("Success");

            await ShowFloatMessage(true);
        }
        else
        {
            if (_pendingFailureAttempt != null)
            {
                _pendingFailureAttempt.Notes = _currentAttemptNotes;
                _pendingFailureAttempt = null;
            }

            _currentAttemptNotes = string.Empty;

            _pendingFailureAttempt = new ProductionLogStepAttempt
            {
                Success = false,
                SubmitTime = DateTimeOffset.UtcNow,
                Notes = ""
            };

            LogStep.Attempts.Add(_pendingFailureAttempt);
            ShowOptionalNotesField = true;
            SetSelectedButton("Failure");

            await OnStepCompleted.InvokeAsync((LogStep, false));
            StateHasChanged();
            await Task.Yield();

            if (_failureNoteTextArea?.Element != null)
            {
                await JsRuntime.InvokeVoidAsync("AutoFocus.setFocus", _failureNoteTextArea.Id);
            }

            await ShowFloatMessage(false);
        }
    }

    /// <summary>
    /// Handles updates when the failure note text changes.
    /// </summary>
    private async Task HandleNoteChangedAsync()
    {
        if (_pendingFailureAttempt != null)
        {
            _pendingFailureAttempt.Notes = _currentAttemptNotes;
            await ProductionLogEventService.ChangeMadeToProductionLog();
        }
    }

    /// <summary>
    /// Shows a floating success or failure message briefly.
    /// </summary>
    /// <param name="isSuccess">True for success message, false for failure message.</param>
    private async Task ShowFloatMessage(bool isSuccess)
    {
        if (isSuccess)
        {
            _showSuccessFloat = true;
            StateHasChanged();
            await Task.Delay(800);
            _showSuccessFloat = false;
        }
        else
        {
            _showFailureFloat = true;
            StateHasChanged();
            await Task.Delay(800);
            _showFailureFloat = false;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Checks whether the latest attempt for the given step was successful.
    /// </summary>
    /// <param name="step">The <see cref="ProductionLogStep"/> to check.</param>
    /// <returns>True if successful; otherwise, false.</returns>
    private bool IsStepSuccessful(ProductionLogStep step) => step.LatestAttempt?.Success == true;

    /// <summary>
    /// Gets the success state of the latest attempt for the given step.
    /// </summary>
    /// <param name="step">The <see cref="ProductionLogStep"/> to check.</param>
    /// <returns>True for success, false for failure, or null if no attempt exists.</returns>
    private bool? GetStepSuccessState(ProductionLogStep step) => step.LatestAttempt?.Success;

    /// <summary>
    /// Determines whether the step has additional details or media to show.
    /// </summary>
    private bool HasDetails => !IsHtmlEmpty(Step.DetailedBody) || (Step.SecondaryMedia?.Count ?? 0) > 0;

    /// <summary>
    /// Checks if an HTML string is empty or contains only whitespace.
    /// </summary>
    /// <param name="html">The HTML string to check.</param>
    /// <returns>True if empty or whitespace; otherwise, false.</returns>
    private static bool IsHtmlEmpty(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return true;
        var textOnly = Regex.Replace(html, "<.*?>", "").Trim();
        return string.IsNullOrWhiteSpace(textOnly);
    }

    private bool _showSuccessFloat = false;
    private bool _showFailureFloat = false;
}
