@using MESS.Data.Models
@inject IJSRuntime JsRuntime

<div class="red-tag-horizontal-wrapper">
    <div class="red-tag-horizontal">
        <div class="red-tag-hole"></div>
        <div class="red-tag-content">
            <h5>REJECTED</h5>

            <div class="inline-info-row">
                <div>
                    <label>Product:</label>
                    <p title="{{ ProductName }}">{{ ProductName }}</p>
                </div>
                <div>
                    <label>Work Instruction:</label>
                    <p title="{{ WorkInstructionName }}">{{ WorkInstructionName }}</p>
                </div>
                <div>
                    <label>Step:</label>
                    <p title="{{ StepDescription }}">{{ StepDescription }}</p>
                </div>
            </div>

            <div class="inline-info-row" style="align-items: flex-end; gap: 1.5rem;">
                <div>
                    <label>Step Attempt ID:</label>
                    <p>{{ StepAttemptId }}</p>
                </div>

                <div style="display: flex; flex-direction: column; min-width: 160px;">
                    <label>Date &amp; Time</label>
                    <input type="datetime-local" />
                </div>

                <div style="display: flex; flex-direction: column; min-width: 120px;">
                    <label>Part</label>
                    <select>
                        <option>Part A</option>
                        <option>Part B</option>
                        <option>Part C</option>
                    </select>
                </div>
            </div>

            <div class="inline-info-row" style="margin-top: 0;">
                <div style="flex: 1 1 100%;">
                    <label>Failure Note:</label>
                    <p class="failure-note-display" style="white-space: normal;">{{ FailureNoteText }}</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex justify-content-end gap-2">
    <button class="btn btn-sm btn-secondary" type="button" @onclick="OnCancelClicked">Cancel</button>
    <button class="btn btn-sm btn-warning" type="button" @onclick="OnSubmitClicked">Submit</button>
</div>

@code {
    [Parameter] public string ProductName { get; set; } = "";
    [Parameter] public string WorkInstructionName { get; set; } = "";
    [Parameter] public string StepDescription { get; set; } = "";
    [Parameter] public string StepAttemptId { get; set; } = "";
    [Parameter] public string FailureNoteText { get; set; } = "";

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }

    private async Task OnCancelClicked() => await OnCancel.InvokeAsync();
    private async Task OnSubmitClicked() => await OnSubmit.InvokeAsync();
}
