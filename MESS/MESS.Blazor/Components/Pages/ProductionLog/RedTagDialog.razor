@using MESS.Data.Models
@using MESS.Services.ProductionLog
@using MESS.Services.WorkInstruction
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JSRuntime
@inject IProductionLogEventService ProductionLogEventService
@implements IDisposable

<div id="red-tag-printable" class="red-tag-horizontal-wrapper print-only" style="width: 456px; height: 228px;">
    <div class="red-tag-horizontal">
        <div class="red-tag-hole"></div>
        <div class="red-tag-content">
            <h5 class="red-tag-header">REJECTED</h5>

            <div class="tag-info-grid">
                <div><span class="label">Date:</span> <span>@DateTime.Now.ToString("g")</span></div>

                @if (_internalAttempts != null && _internalAttempts.Count > 0)
                {
                    <div><span class="label">ID:</span> <span>@AttemptNumber</span></div>
                }
                else
                {
                    <div><span class="label">ID:</span> <span>None</span></div>
                }

                <div><span class="label">Product:</span> <span>@_productName</span></div>
                <div><span class="label">Part Name:</span> <span>@_partName</span></div>

                <div><span class="label">Part #:</span> <span>@_partNumber</span></div>
                <div><span class="label">Work Instruction:</span> <span>@_workInstructionName</span></div>

                <div><span class="label">Operator:</span> <span>@OperatorName</span></div>
            </div>
            <div>
                <span class="label">Step:</span>
                <span class="step-truncate">@StepDescription</span>
            </div>

            <div class="failure-note-row">
                <span class="label">Failure Note:</span>
                <div class="failure-note">@FailureNoteText</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex justify-content-end gap-2">
    <button class="btn btn-sm btn-secondary" type="button" @onclick="OnCancelClicked">Cancel</button>
    <button class="btn btn-sm btn-secondary" type="button" @onclick="OnSubmitClicked">Print</button>
</div>

@code {
    /// <summary>
    /// A backing list to store step attempts for display and tracking.
    /// </summary>
    private List<ProductionLogStepAttempt> _internalAttempts = new();

    /// <summary>
    /// The current product name being displayed.
    /// </summary>
    private string _productName = string.Empty;

    /// <summary>
    /// Indicates whether the product name has been explicitly set by a parent component.
    /// </summary>
    private bool _productNameExplicitlySet = false;

    /// <summary>
    /// The current work instruction name being displayed.
    /// </summary>
    private string _workInstructionName = string.Empty;

    /// <summary>
    /// Indicates whether the work instruction name has been explicitly set by a parent component.
    /// </summary>
    private bool _workInstructionNameExplicitlySet = false;

    /// <summary>
    /// The current part name being displayed.
    /// </summary>
    private string _partName = string.Empty;

    /// <summary>
    /// The current part number being displayed.
    /// </summary>
    private string _partNumber = string.Empty;

    /// <summary>
    /// Gets or sets the name of the product.
    /// If set externally, this value will not be overridden by service updates.
    /// </summary>
    [Parameter]
    public string? ProductName { get; set; }

    /// <summary>
    /// Gets or sets the name of the work instruction.
    /// If set externally, this value will not be overridden by service updates.
    /// </summary>
    [Parameter]
    public string WorkInstructionName { get; set; } = "Unavailable";

    /// <summary>
    /// Gets or sets the description of the step associated with the failure.
    /// </summary>
    [Parameter] public string StepDescription { get; set; } = "";

    /// <summary>
    /// Gets or sets the collection of step attempts for the current operation.
    /// </summary>
    [Parameter] public List<ProductionLogStepAttempt> Attempts { get; set; } = new();

    /// <summary>
    /// Gets or sets the failure note content explaining why the step was rejected.
    /// </summary>
    [Parameter] public string FailureNoteText { get; set; } = "";

    /// <summary>
    /// Gets or sets the currently selected product ID.
    /// </summary>
    [Parameter] public int SelectedProductId { get; set; }

    /// <summary>
    /// Callback invoked when the selected product ID is changed.
    /// </summary>
    [Parameter] public EventCallback<int> SelectedProductIdChanged { get; set; }

    /// <summary>
    /// Gets or sets the name of the currently logged-in operator.
    /// </summary>
    [Parameter] public string OperatorName { get; set; } = string.Empty;

    /// <summary>
    /// Callback invoked when the Cancel button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>
    /// Callback invoked when the Print button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    /// <summary>
    /// Gets or sets the associated work instruction object.
    /// </summary>
    [Parameter] public WorkInstruction? WorkInstruction { get; set; }

    /// <summary>
    /// Gets or sets the part name for display.
    /// </summary>
    [Parameter] public string PartName { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the part number for display.
    /// </summary>
    [Parameter] public string PartNumber { get; set; } = string.Empty;

    /// <summary>
    /// Called when component parameters are set. Handles synchronization of attempts, product name,
    /// work instruction name, and part info from parameters, backing services, or related models.
    /// </summary>
    protected override void OnParametersSet()
    {
        // Sync attempts to internal list
        if (Attempts != null)
        {
            _internalAttempts = new List<ProductionLogStepAttempt>(Attempts);
        }

        // Product name sync
        if (!_productNameExplicitlySet && !string.IsNullOrWhiteSpace(ProductName))
        {
            _productName = ProductName!;
            _productNameExplicitlySet = true;
        }

        // Work instruction name sync
        if (!_workInstructionNameExplicitlySet && !string.IsNullOrWhiteSpace(WorkInstructionName) && WorkInstructionName != "Unavailable")
        {
            _workInstructionName = WorkInstructionName;
            _workInstructionNameExplicitlySet = true;
        }

        // Fallback to service product name if not explicitly set
        if (!_productNameExplicitlySet)
        {
            var svcProdName = ProductionLogEventService.CurrentProductName;
            if (!string.IsNullOrWhiteSpace(svcProdName) && _productName != svcProdName)
            {
                _productName = svcProdName;
            }
        }

        // Fallback to WorkInstruction object title or service name
        if (!_workInstructionNameExplicitlySet)
        {
            if (WorkInstruction != null && !string.IsNullOrWhiteSpace(WorkInstruction.Title))
            {
                _workInstructionName = WorkInstruction.Title;
                _workInstructionNameExplicitlySet = true;
                ProductionLogEventService.SetCurrentWorkInstructionName(_workInstructionName);
            }
            else
            {
                var svcWIName = ProductionLogEventService.CurrentWorkInstructionName;
                if (!string.IsNullOrWhiteSpace(svcWIName) && _workInstructionName != svcWIName)
                {
                    _workInstructionName = svcWIName;
                }
                else if (string.IsNullOrWhiteSpace(_workInstructionName))
                {
                    Console.WriteLine("Warning: WorkInstructionName is empty from both parameter and service.");
                }
            }
        }

        // Part name and number sync
        _partName = PartName;
        _partNumber = PartNumber;
    }

    /// <summary>
    /// Initializes component state and subscribes to service events.
    /// </summary>
    protected override void OnInitialized()
    {
        ProductionLogEventService.ProductDetailsChanged += OnProductDetailsChanged;
        ProductionLogEventService.WorkInstructionDetailsChanged += OnWorkInstructionDetailsChanged;
        ProductionLogEventService.ProductionLogEventChanged += OnProductionLogChanged;

        if (!_productNameExplicitlySet)
        {
            _productName = ProductionLogEventService.CurrentProductName ?? string.Empty;
        }

        if (!_workInstructionNameExplicitlySet)
        {
            var svcWIName = ProductionLogEventService.CurrentWorkInstructionName ?? string.Empty;
            _workInstructionName = svcWIName;

            if (string.IsNullOrWhiteSpace(svcWIName))
            {
                Console.WriteLine("⚠ Warning: WorkInstructionName is empty during initialization.");
            }
        }
    }

    /// <summary>
    /// Gets the number of step attempts associated with the current log entry.
    /// </summary>
    private int AttemptNumber => _internalAttempts?.Count ?? 0;

    /// <summary>
    /// Handles updates to the product name from the production log service.
    /// </summary>
    private void OnProductDetailsChanged()
    {
        if (!_productNameExplicitlySet)
        {
            var svcName = ProductionLogEventService.CurrentProductName;
            if (!string.IsNullOrWhiteSpace(svcName) && _productName != svcName)
            {
                _productName = svcName;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    /// <summary>
    /// Handles updates to the work instruction name from the production log service.
    /// </summary>
    private void OnWorkInstructionDetailsChanged()
    {
        if (!_workInstructionNameExplicitlySet)
        {
            var svcName = ProductionLogEventService.CurrentWorkInstructionName;
            if (!string.IsNullOrWhiteSpace(svcName) && _workInstructionName != svcName)
            {
                _workInstructionName = svcName;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    /// <summary>
    /// Triggers a UI refresh when the production log changes.
    /// </summary>
    private void OnProductionLogChanged() => InvokeAsync(StateHasChanged);

    /// <summary>
    /// Called when the Cancel button is clicked.
    /// Triggers the <see cref="OnCancel"/> callback.
    /// </summary>
    private async Task OnCancelClicked() => await OnCancel.InvokeAsync();

    /// <summary>
    /// Called when the Print button is clicked.
    /// Triggers JavaScript print logic and the <see cref="OnSubmit"/> callback.
    /// </summary>
    private async Task OnSubmitClicked()
    {
        if (module != null)
        {
            await module.InvokeVoidAsync("printRedTagById", "red-tag-printable");
        }
        await OnSubmit.InvokeAsync();
    }

    /// <summary>
    /// Reference to the JavaScript module used for printing.
    /// </summary>
    private IJSObjectReference? module;

    /// <summary>
    /// Loads the JavaScript print module after the first render.
    /// </summary>
    /// <param name="firstRender">Whether this is the first render.</param>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                new object[] { "./Components/Pages/ProductionLog/Create.razor.js" }
            );
        }
    }

    /// <summary>
    /// Disposes event subscriptions to prevent memory leaks.
    /// </summary>
    public void Dispose()
    {
        ProductionLogEventService.ProductDetailsChanged -= OnProductDetailsChanged;
        ProductionLogEventService.WorkInstructionDetailsChanged -= OnWorkInstructionDetailsChanged;
        ProductionLogEventService.ProductionLogEventChanged -= OnProductionLogChanged;
    }

    /// <summary>
    /// Disposes the JavaScript module reference asynchronously.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
