@using MESS.Data.Models
@using MESS.Services.ProductionLog
@using MESS.Services.WorkInstruction
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JsRuntime
@inject IProductionLogEventService ProductionLogEventService
@implements IDisposable

<div class="red-tag-horizontal-wrapper" style="width: 456px; height: 228px;">
    <div class="red-tag-horizontal">
        <div class="red-tag-hole"></div>
        <div class="red-tag-content">
            <h5 class="red-tag-header">REJECTED</h5>

            <div class="tag-info-grid">
                <div><span class="label">Date:</span> <span>@DateTime.Now.ToString("g")</span></div>
                <div><span class="label">Step Attempt ID:</span> <span>@StepAttemptId</span></div>

                <div><span class="label">Product:</span> <span>@ProductName</span></div>
                <div><span class="label">Part Name:</span> <span></span></div>

                <div><span class="label">Part #:</span> <span></span></div>
                <div><span class="label">Work Instruction:</span> <span>@WorkInstructionName</span></div>

                <div><span class="label">Operator:</span> <span>@OperatorName</span></div>
            </div>
            <div>
                <span class="label">Step:</span>
                <span class="step-truncate">@StepDescription</span>
            </div>

            <div class="failure-note-row">
                <span class="label">Failure Note:</span>
                <div class="failure-note">@FailureNoteText</div>
            </div>
        </div>
    </div>
</div>






<div class="mt-3 d-flex justify-content-end gap-2">
    <button class="btn btn-sm btn-secondary" type="button" @onclick="OnCancelClicked">Cancel</button>
    <button class="btn btn-sm btn-secondary" type="button" @onclick="OnSubmitClicked">Print</button>
</div>

@code {
    /// <summary>
    /// Gets or sets the name of the product associated with this rejection tag.
    /// </summary>
    [Parameter] public string ProductName { get; set; } = "";

    /// <summary>
    /// Gets or sets the name of the work instruction associated with this rejection tag.
    /// </summary>
    [Parameter] public string WorkInstructionName { get; set; } = "";

    /// <summary>
    /// Gets or sets the description of the step where the failure occurred.
    /// </summary>
    [Parameter] public string StepDescription { get; set; } = "";

    /// <summary>
    /// The unique identifier for the current step attempt in the production log.
    /// </summary>
    [Parameter] public string StepAttemptId { get; set; } = string.Empty;
    
    /// <summary>
    /// Represents the automatically generated timestamp for when the component is initialized.
    /// This value is system-assigned and not intended for user input.
    /// </summary>
    [Parameter] public DateTime Timestamp { get; set; } = DateTime.Now;

    /// <summary>
    /// Gets or sets the failure note text explaining the rejection.
    /// </summary>
    [Parameter] public string FailureNoteText { get; set; } = "";

    /// <summary>
    /// Gets or sets the currently selected product ID.
    /// </summary>
    [Parameter] public int SelectedProductId { get; set; }

    /// <summary>
    /// Event callback triggered when the selected product ID changes.
    /// </summary>
    [Parameter] public EventCallback<int> SelectedProductIdChanged { get; set; }
    
    /// <summary>
    /// The name of the operator who is currently logged in and submitting the tag.
    /// </summary>
    [Parameter] public string OperatorName { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the callback triggered when the Cancel button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>
    /// Gets or sets the callback triggered when the Print button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnSubmit { get; set; }

    /// <summary>
    /// Gets or sets the work instruction containing nodes such as <see cref="PartNode"/>.
    /// </summary>
    [Parameter] public WorkInstruction? WorkInstruction { get; set; }

    /// <summary>
    /// Called when the component is initialized. Subscribes to event callbacks from <see cref="IProductionLogEventService"/>.
    /// </summary>
    protected override void OnInitialized()
    {
        ProductionLogEventService.ProductDetailsChanged += OnProductDetailsChanged;
        ProductionLogEventService.WorkInstructionDetailsChanged += OnWorkInstructionDetailsChanged;
        ProductionLogEventService.ProductionLogEventChanged += OnProductionLogChanged;

        ProductName = ProductionLogEventService.CurrentProductName;
        WorkInstructionName = ProductionLogEventService.CurrentWorkInstructionName;
        StepAttemptId = ProductionLogEventService.CurrentProductionLog?.StepAttemptId ?? "";
        
        StateHasChanged();
    }
    
    /// <summary>
    /// Handles updates to the product name when the corresponding service event is triggered.
    /// </summary>
    private void OnProductDetailsChanged()
    {
        ProductName = ProductionLogEventService.CurrentProductName;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Handles updates to the work instruction name when the corresponding service event is triggered.
    /// </summary>
    private void OnWorkInstructionDetailsChanged()
    {
        WorkInstructionName = ProductionLogEventService.CurrentWorkInstructionName;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Handles updates to the production log when the corresponding service event is triggered.
    /// </summary>
    private void OnProductionLogChanged()
    {
        StepAttemptId = ProductionLogEventService.CurrentProductionLog?.StepAttemptId ?? "";
        InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// Invokes the <see cref="OnCancel"/> callback when the Cancel button is clicked.
    /// </summary>
    private async Task OnCancelClicked() => await OnCancel.InvokeAsync();

    /// <summary>
    /// Invokes the <see cref="OnSubmit"/> callback when the Print button is clicked.
    /// </summary>
    private async Task OnSubmitClicked() => await OnSubmit.InvokeAsync();

    /// <summary>
    /// Unsubscribes from event handlers to prevent memory leaks.
    /// </summary>
    public void Dispose()
    {
        ProductionLogEventService.ProductDetailsChanged -= OnProductDetailsChanged;
        ProductionLogEventService.WorkInstructionDetailsChanged -= OnWorkInstructionDetailsChanged;
        ProductionLogEventService.ProductionLogEventChanged -= OnProductionLogChanged;
    }
}
