@using MESS.Data.Models
@using MESS.Blazor.Components.Pages.ProductionLog.WorkInstructionNodes
@using PartNode = MESS.Data.Models.PartNode
@using MESS.Blazor.Components.Pages.ProductionLog.WorkInstructionNodes.PartNode
@using MESS.Services.DTOs.ProductionLogs.Form
@using MESS.Services.DTOs.ProductionLogs.LogSteps.Form
@using MESS.Services.UI.PartTraceability
@inject IPartTraceabilityStateService PartTraceabilityService

@if (ProductionLogs.Any())
{
    <ul class="step">
        @foreach (var block in NodeBlocks)
        {
            switch (block)
            {
                case Step step:
                    var logSteps = new List<LogStepFormDTO>();
                    foreach (var log in ProductionLogs)
                    {
                        var existing = log.LogSteps.FirstOrDefault(ls => ls.WorkInstructionStepId == step.Id);
                        if (existing == null)
                        {
                            existing = new LogStepFormDTO { WorkInstructionStepId = step.Id };
                            log.LogSteps.Add(existing);
                        }
                        logSteps.Add(existing);
                    }

                    <li class="mb-3">
                        <div id="step-@step.Position">
                            <StepNodeListItem
                                Step="step"
                                LogSteps="logSteps"
                                OnStepCompleted="OnStepCompleted" />
                        </div>
                    </li>
                    break;

                case List<PartNode> partGroup:
                    <li class="mb-3">
                        <PartNodeGroup PartNodes="partGroup" ProductionLogs="ProductionLogs" />
                    </li>
                    break;
            }
        }

        @if (ActiveWorkInstruction.PartProduced is not null)
        {
            <div class="card card-body mt-3">

                @* Serial Number Input (if serialized) *@
                @if (ActiveWorkInstruction.PartProducedIsSerialized)
                {
                    <div class="mb-3 d-flex flex-wrap gap-2 justify-content-around">
                        @for (var i = 0; i < ProductionLogs.Count; i++)
                        {
                            var index = i;
                            <div class="card mb-1 flex-grow-1" style="min-width: 150px;">
                                <div class="card-header d-flex align-items-center justify-content-between py-2">
                                    <span class="fw-semibold">Produced Serial Number</span>
                                    @if (ProductionLogs.Count > 1)
                                    {
                                        <small class="text-muted">#@(index + 1)</small>
                                    }
                                </div>
                                <div class="card-body py-2">
                                    <input
                                        id=@($"producedSerialNumber-{index}")
                                        class="form-control tall-input text-lightweight"
                                        placeholder="Enter serial number"
                                        @oninput="@(e => OnProducedSerialInput(index, e.Value?.ToString()))" />
                                </div>
                            </div>
                        }
                    </div>
                }

                @* Tag Code Input *@
                <div class="mb-2">
                    <div class="form-label">
                        @(ProductionLogs.Count == 1 ? "Produced Tag Code" : "Produced Tag Codes")
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 justify-content-around">
                    @for (var i = 0; i < ProductionLogs.Count; i++)
                    {
                        var index = i;

                        <div class="card mb-1 flex-grow-1" style="min-width: 150px;">
                            <div class="card-header d-flex align-items-center justify-content-between py-2">
                                <span class="fw-semibold">Tag Code</span>
                                @if (ProductionLogs.Count > 1)
                                {
                                    <small class="text-muted">#@(index + 1)</small>
                                }
                            </div>
                            <div class="card-body py-2">
                                <input
                                    id=@($"producedTagCode-{index}")
                                    class="form-control tall-input text-lightweight"
                                    placeholder="Scan or enter tag code"
                                    @oninput="@(async e => await OnProducedTagInput(index, e.Value?.ToString()))" />

                                @* Optional status / validation message *@
                                @* You can use a small text under the input like in PartNodeTextInput *@
                                <div class="form-text text-muted small mt-1">
                                    @(/* Optionally show "Searching..." or validation here */ "")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </ul>
}

@code {
    /// <summary>
    /// The active work instruction being processed.
    /// </summary>
    [Parameter] public required WorkInstruction ActiveWorkInstruction { get; set; }

    /// <summary>
    /// The production logs associated with the current work instruction.
    /// </summary>
    [Parameter] public required List<ProductionLogFormDTO> ProductionLogs { get; set; }

    /// <summary>
    /// Event callback triggered when a step is completed.
    /// The tuple contains the production log step and an optional boolean indicating completion status.
    /// </summary>
    [Parameter] public EventCallback<(List<LogStepFormDTO>, bool?)> OnStepCompleted { get; set; }
    
    /// <summary>
    /// A processed list of "blocks" — each block is either a Step node or a group of Part nodes.
    /// </summary>
    private List<object> NodeBlocks { get; set; } = [];

    /// <inheritdoc/>
    protected override void OnParametersSet()
    {
        NodeBlocks = GroupNodes(ActiveWorkInstruction.Nodes.OrderBy(n => n.Position).ToList());
    }

    private static List<object> GroupNodes(List<WorkInstructionNode> nodes)
    {
        var result = new List<object>();
        List<PartNode>? currentGroup = null;

        foreach (var node in nodes)
        {
            if (node is PartNode partNode)
            {
                currentGroup ??= [];
                currentGroup.Add(partNode);
            }
            else
            {
                if (currentGroup is not null)
                {
                    result.Add(currentGroup);
                    currentGroup = null;
                }

                if (node is Step step)
                    result.Add(step);
            }
        }

        // Add the final group if the list ended with part nodes
        if (currentGroup is not null)
            result.Add(currentGroup);

        return result;
    }
    
    private void OnProducedSerialInput(int logIndex, string? value)
    {
        // Normalize empty input to null
        var serialNumber = string.IsNullOrWhiteSpace(value) ? null : value;

        // Update the state service
        PartTraceabilityService.SetProducedPartSerialNumber(logIndex, serialNumber);
    }
    
    private async Task OnProducedTagInput(int logIndex, string? value)
    {
        var tagCode = string.IsNullOrWhiteSpace(value) ? null : value;

        // Update the state service asynchronously
        await PartTraceabilityService.SetProducedPartTagCodeAsync(logIndex, tagCode);

        // Optionally trigger a UI refresh if needed
        StateHasChanged();
    }
}