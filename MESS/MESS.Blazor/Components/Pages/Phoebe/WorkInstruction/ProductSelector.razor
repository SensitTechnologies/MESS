@using MESS.Data.Models
@using Microsoft.AspNetCore.Components

<div class="list-group scrollable-checkbox-container">
    @if (AllProducts == null)
    {
        <div class="text-muted">Loading products...</div>
    }
    else
    {
        @foreach (var product in AllProducts)
        {
            <div class="list-group-item d-flex align-items-center gap-2">
                <input type="checkbox"
                       class="form-check-input me-1"
                       checked="@IsProductSelected(product.Id)"
                       @onchange="@((ChangeEventArgs e) => ToggleProductSelection(product, e.Value?.ToString() == "true"))" />

                <input class="form-control"
                       value="@product.Name"
                       @onchange="@((ChangeEventArgs e) => OnProductChanged.InvokeAsync((product, e.Value?.ToString() ?? string.Empty)))"
                       placeholder="Product name" />
            </div>
        }

        <div class="list-group-item d-flex justify-content-between align-items-center">
            <button class="btn btn-sm btn-outline-primary" @onclick="AddNewProduct">
                + Add Product
            </button>
            <div class="ms-auto">
                <button class="btn btn-sm btn-outline-primary" @onclick="() => OnSaveClicked.InvokeAsync()">
                    Save
                </button>
            </div>
        </div>
    }
</div>

@code {
    /// <summary>
    /// List of all products to show.
    /// </summary>
    [Parameter, EditorRequired]
    public List<Product> AllProducts { get; set; } = new();

    /// <summary>
    /// List of selected product IDs.
    /// </summary>
    [Parameter]
    public List<int> SelectedProductIds { get; set; } = new();

    /// <summary>
    /// Event fired when selected products change, passing list of selected product IDs.
    /// </summary>
    [Parameter]
    public EventCallback<List<int>> SelectedProductIdsChanged { get; set; }

    /// <summary>
    /// Event callback triggered when the list of selected products changes.
    /// Sends a list of the currently selected <see cref="Product"/> instances.
    /// </summary>
    [Parameter]
    public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Invoked when a product's name changes.
    /// </summary>
    [Parameter]
    public EventCallback<(Product product, string newName)> OnProductChanged { get; set; }

    /// <summary>
    /// Invoked when a new product is added.
    /// </summary>
    [Parameter]
    public EventCallback<Product> OnProductAdded { get; set; }

    /// <summary>
    /// Invoked when the user clicks the Save button.
    /// </summary>
    [Parameter]
    public EventCallback OnSaveClicked { get; set; }

    private bool IsProductSelected(int productId) =>
        SelectedProductIds.Contains(productId);

    private async Task ToggleProductSelection(Product product, bool isChecked)
    {
        if (isChecked)
        {
            if (!SelectedProductIds.Contains(product.Id))
                SelectedProductIds.Add(product.Id);
        }
        else
        {
            SelectedProductIds.Remove(product.Id);
        }

        await SelectedProductIdsChanged.InvokeAsync(SelectedProductIds);
        if (OnProductsChanged.HasDelegate)
            await OnProductsChanged.InvokeAsync(
                AllProducts.Where(p => SelectedProductIds.Contains(p.Id)).ToList()
            );

    }

    private async Task AddNewProduct()
    {
        var newProduct = new Product { Id = 0, Name = "New Product" };
        AllProducts.Add(newProduct);

        // Optionally auto-select the new product
        SelectedProductIds.Add(newProduct.Id);
        await SelectedProductIdsChanged.InvokeAsync(SelectedProductIds);
        if (OnProductsChanged.HasDelegate)
            await OnProductsChanged.InvokeAsync(
                AllProducts.Where(p => SelectedProductIds.Contains(p.Id)).ToList()
            );

        if (OnProductAdded.HasDelegate)
            await OnProductAdded.InvokeAsync(newProduct);
    }
}
