@using MESS.Services.DTOs.Products.Detail

<div class="list-group scrollable-checkbox-container">
    @foreach (var product in AllProducts)
    {
        var isSelected = IsProductSelected(product.Name);
        var isSaved = product.ProductId > 0;

        <div class="list-group-item d-flex align-items-center justify-content-between">

            <div class="d-flex align-items-center gap-2">
                <input type="checkbox"
                       class="form-check-input"
                       checked="@isSelected"
                       @onchange="@(e => ToggleProductSelection(product.Name, e.Value is bool b && b))" />

                <span>@product.Name</span>
            </div>

            <div class="d-flex align-items-center gap-2">

                @if (isSaved)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle"></i> Saved
                    </span>
                }
                else if (isSelected)
                {
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-hourglass-split"></i> Creation Pending
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        <i class="bi bi-x-circle"></i> Will Not Save
                    </span>

                    <button class="btn btn-sm btn-outline-danger"
                            title="Remove product"
                            @onclick="() => RemoveUnsavedProduct(product)">
                        <i class="bi bi-trash"></i>
                    </button>
                }

            </div>
        </div>
    }

    @foreach (var product in UnsavedProducts)
    {
        <div class="list-group-item d-flex gap-2">

            <input class="form-control"
                   @bind="product.Name"
                   placeholder="Product name"
                   @onblur="@(() => SaveNewProductAsync(product))" />

            <button class="btn btn-outline-danger btn-sm"
                    @onclick="() => RemovePendingProduct(product)">
                <i class="bi bi-trash"></i>
            </button>

        </div>
    }

    <div class="list-group-item d-flex justify-content-between align-items-center">
        <button class="btn btn-sm btn-outline-primary" @onclick="AddNewProduct">
            + Add Product
        </button>
    </div>
</div>

@code {
    /// <summary>
    /// All products available for display (optional metadata retained for UI).
    /// </summary>
    [Parameter, EditorRequired]
    public List<ProductDetailDTO> AllProducts { get; set; } = new();

    /// <summary>
    /// Currently selected product names.
    /// </summary>
    [Parameter]
    public List<string> SelectedProducts { get; set; } = new();

    /// <summary>
    /// Event callback invoked whenever selected products change.
    /// </summary>
    [Parameter]
    public EventCallback<List<string>> SelectedProductsChanged { get; set; }

    /// <summary>
    /// Unsaved product names being created by the user.
    /// </summary>
    private List<PendingProduct> UnsavedProducts { get; set; } = [];

    private bool IsProductSelected(string name) =>
        SelectedProducts.Contains(name);

    private async Task ToggleProductSelection(string name, bool isChecked)
    {
        var updated = SelectedProducts.ToList();

        if (isChecked)
        {
            if (!updated.Contains(name))
                updated.Add(name);
        }
        else
        {
            updated.Remove(name);
        }

        SelectedProducts = updated;
        await SelectedProductsChanged.InvokeAsync(updated);
    }

    private void AddNewProduct()
    {
        UnsavedProducts.Add(new PendingProduct());
    }
    
    private void RemoveUnsavedProduct(ProductDetailDTO product)
    {
        if (product.ProductId != 0)
            return;

        AllProducts.Remove(product);
        SelectedProducts.Remove(product.Name);
    }
    
    private void RemovePendingProduct(PendingProduct pending)
    {
        UnsavedProducts.Remove(pending);
    }

    private async Task SaveNewProductAsync(PendingProduct pending)
    {
        if (string.IsNullOrWhiteSpace(pending.Name))
            return;

        if (AllProducts.Any(p => 
                p.Name.Equals(pending.Name, StringComparison.OrdinalIgnoreCase)))
        {
            UnsavedProducts.Remove(pending);
            return;
        }

        var productDto = new ProductDetailDTO
        {
            ProductId = 0,
            Name = pending.Name.Trim(),
            IsActive = true
        };

        AllProducts.Add(productDto);
        UnsavedProducts.Remove(pending);

        if (!SelectedProducts.Contains(productDto.Name))
            SelectedProducts.Add(productDto.Name);

        await SelectedProductsChanged.InvokeAsync(SelectedProducts);
    }
    
    private class PendingProduct
    {
        public string Name { get; set; } = "";
    }
}