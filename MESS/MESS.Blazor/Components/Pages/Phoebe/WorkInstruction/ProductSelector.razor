@using MESS.Data.Models
@using MESS.Services.Product
@inject IProductService ProductService
@inject IToastService ToastService

<div class="list-group scrollable-checkbox-container">
    @if (AllProducts == null)
    {
        <div class="text-muted">Loading products...</div>
    }
    else
    {
        @for (int i = 0; i < AllProducts.Count; i++)
        {
            var product = AllProducts[i];
            <div class="list-group-item d-flex align-items-center gap-2" @key="product.Id">
                <input type="checkbox"
                       class="form-check-input me-1"
                       checked="@IsProductSelected(product.Id)"
                       @onchange="e => ToggleProductSelection(product, e.Value as bool? ?? false)" />
                <input type="text"
                       class="form-control form-control-sm flex-grow-1"
                       value="@product.Name"
                       @oninput="async e => await OnProductNameChanged(i, ((ChangeEventArgs)e).Value?.ToString() ?? string.Empty)" />
            </div>
        }

        <div class="mt-2 text-end">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddNewProduct">
                Add Product
            </button>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The current work instruction for which products are selected.
    /// </summary>
    [Parameter, EditorRequired]
    public WorkInstruction WorkInstruction { get; set; } = default!;

    /// <summary>
    /// The full list of products available to select from.
    /// </summary>
    [Parameter, EditorRequired]
    public List<Product> AllProducts { get; set; } = new();

    /// <summary>
    /// Event triggered when the selected products list changes.
    /// </summary>
    [Parameter]
    public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Determines if a product is selected for the current work instruction.
    /// </summary>
    /// <param name="productId">Product identifier.</param>
    /// <returns>True if selected; otherwise false.</returns>
    private bool IsProductSelected(int productId) =>
        WorkInstruction.Products?.Any(p => p.Id == productId) ?? false;

    /// <summary>
    /// Toggles the selection state of a product.
    /// Adds or removes the product from the work instruction's products list.
    /// </summary>
    /// <param name="product">The product to toggle.</param>
    /// <param name="isChecked">Whether the product is selected.</param>
    private async Task ToggleProductSelection(Product product, bool isChecked)
    {
        WorkInstruction.Products ??= new List<Product>();

        if (isChecked)
        {
            if (!WorkInstruction.Products.Any(p => p.Id == product.Id))
                WorkInstruction.Products.Add(product);
        }
        else
        {
            WorkInstruction.Products.RemoveAll(p => p.Id == product.Id);
        }

        await OnProductsChanged.InvokeAsync(WorkInstruction.Products);
    }

    /// <summary>
    /// Adds a new product with a timestamped name, persists it, refreshes the product list,
    /// selects the new product, and notifies the parent component.
    /// </summary>
    private async Task AddNewProduct()
    {
        var timestamp = DateTime.Now.ToString("HHmmss");
        var newProduct = new Product { Name = $"New Product {timestamp}" };

        try
        {
            await ProductService.CreateAsync(newProduct);

            var updatedProducts = (await ProductService.GetAllAsync()).ToList();

            AllProducts.Clear();
            AllProducts.AddRange(updatedProducts);

            var added = updatedProducts.FirstOrDefault(p => p.Name == newProduct.Name);

            if (added != null)
            {
                await ToggleProductSelection(added, true);
                await OnProductsChanged.InvokeAsync(WorkInstruction.Products ?? new());
                StateHasChanged();
            }
            else
            {
                ToastService.ShowWarning("Product added but not found in refreshed list.");
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            ToastService.ShowError("Failed to add and save new product.");
        }
    }

    /// <summary>
    /// Handles changes to a product's name in the UI and updates the database.
    /// </summary>
    /// <param name="index">Index of the product in the list.</param>
    /// <param name="newName">The new name for the product.</param>
    private async Task OnProductNameChanged(int index, string newName)
    {
        if (index < 0 || index >= AllProducts.Count || string.IsNullOrWhiteSpace(newName))
            return;

        var product = AllProducts[index];
        product.Name = newName.Trim();

        try
        {
            await ProductService.UpdateProductAsync(product);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            ToastService.ShowError("Failed to update product name.");
        }

        await OnProductsChanged.InvokeAsync(WorkInstruction.Products ?? new());
    }
}
