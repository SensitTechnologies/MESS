@using MESS.Data.Models
@using MESS.Services.Product

<div class="list-group scrollable-checkbox-container">
    @if (AllProducts == null)
    {
        <div class="text-muted">Loading products...</div>
    }
    else
    {
        @for (int i = 0; i < AllProducts.Count; i++)
        {
            var product = AllProducts[i];
            <div class="list-group-item d-flex align-items-center gap-2" @key="product.Id">
                <input type="checkbox"
                       class="form-check-input me-1"
                       checked="@IsProductSelected(product.Id)"
                       @onchange="e => ToggleProductSelection(product, e.Value as bool? ?? false)" />
                <input type="text"
                       class="form-control form-control-sm flex-grow-1"
                       value="@product.Name"
                       @oninput="e => OnProductNameChanged(i, e.Value?.ToString())" />
            </div>
        }

        <div class="mt-2 text-end">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddNewProduct">
                Add Product
            </button>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The work instruction associated with the product selection.
    /// </summary>
    [Parameter] public WorkInstruction WorkInstruction { get; set; } = default!;

    /// <summary>
    /// The list of all available products.
    /// </summary>
    [Parameter] public required List<Product> AllProducts { get; set; }

    /// <summary>
    /// Event callback triggered when the selected products or product names change.
    /// </summary>
    [Parameter] public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Checks if a product is selected in the current work instruction.
    /// </summary>
    private bool IsProductSelected(int productId)
        => WorkInstruction.Products?.Any(p => p.Id == productId) ?? false;

    /// <summary>
    /// Toggles the selection state of a product in the current work instruction.
    /// </summary>
    private async Task ToggleProductSelection(Product product, bool isChecked)
    {
        WorkInstruction.Products ??= new();

        if (isChecked)
        {
            if (WorkInstruction.Products.All(p => p.Id != product.Id))
            {
                WorkInstruction.Products.Add(product);
            }
        }
        else
        {
            WorkInstruction.Products.RemoveAll(p => p.Id == product.Id);
        }

        await OnProductsChanged.InvokeAsync(WorkInstruction.Products);
    }

    /// <summary>
    /// Adds a new product with a temporary negative ID and default name, then selects it.
    /// </summary>
    private async Task AddNewProduct()
    {
        var newProduct = new Product
        {
            Id = -1 * (AllProducts.Count + 1), // temporary unique negative ID
            Name = "New Product"
        };
        AllProducts.Add(newProduct);

        // Immediately select the new product in the work instruction
        await ToggleProductSelection(newProduct, true);

        StateHasChanged();
    }

    /// <summary>
    /// Updates the product name and notifies parent component of the change.
    /// Validates index to avoid exceptions.
    /// </summary>
    private async Task OnProductNameChanged(int index, string? newName)
    {
        if (index < 0 || index >= AllProducts.Count)
        {
            // Invalid index, ignore gracefully
            return;
        }

        if (!string.IsNullOrWhiteSpace(newName))
        {
            AllProducts[index].Name = newName;

            // Notify parent about the product list changes
            await OnProductsChanged.InvokeAsync(WorkInstruction.Products ?? new List<Product>());
        }
    }
}
