@using MESS.Services.CRUD.Products
@using MESS.Services.DTOs.Products.Detail

@inject IProductService ProductService

<div class="list-group scrollable-checkbox-container">
    @foreach (var product in AllProducts)
    {
        <div class="list-group-item d-flex align-items-center gap-2">
            <input type="checkbox"
                   class="form-check-input me-1"
                   checked="@IsProductSelected(product.Name)"
                   @onchange="@(e => ToggleProductSelection(product.Name, e.Value is bool b && b))" />

            <span>@product.Name</span>
        </div>
    }

    @foreach (var name in UnsavedProducts)
    {
        <input class="form-control"
               value="@name"
               @onchange="(e => UpdateUnsavedProductName(name, e.Value?.ToString()))"
               placeholder="Product name"
               @onblur="@(() => SaveNewProductAsync(name))" />
    }

    <div class="list-group-item d-flex justify-content-between align-items-center">
        <button class="btn btn-sm btn-outline-primary" @onclick="AddNewProduct">
            + Add Product
        </button>
    </div>
</div>

@code {
    /// <summary>
    /// All products available for display (optional metadata retained for UI).
    /// </summary>
    [Parameter, EditorRequired]
    public List<ProductDetailDTO> AllProducts { get; set; } = new();

    /// <summary>
    /// Currently selected product names.
    /// </summary>
    [Parameter]
    public List<string> SelectedProducts { get; set; } = new();

    /// <summary>
    /// Event callback invoked whenever selected products change.
    /// </summary>
    [Parameter]
    public EventCallback<List<string>> SelectedProductsChanged { get; set; }

    /// <summary>
    /// Unsaved product names being created by the user.
    /// </summary>
    private List<string> UnsavedProducts { get; set; } = new();

    private bool IsProductSelected(string name) =>
        SelectedProducts.Contains(name);

    private async Task ToggleProductSelection(string name, bool isChecked)
    {
        var updated = SelectedProducts.ToList();

        if (isChecked)
        {
            if (!updated.Contains(name))
                updated.Add(name);
        }
        else
        {
            updated.Remove(name);
        }

        SelectedProducts = updated;
        await SelectedProductsChanged.InvokeAsync(updated);
    }

    private void AddNewProduct()
    {
        UnsavedProducts.Add(string.Empty);
    }

    private void UpdateUnsavedProductName(string oldName, string? newName)
    {
        if (string.IsNullOrWhiteSpace(newName))
            return;

        var index = UnsavedProducts.IndexOf(oldName);
        if (index >= 0)
            UnsavedProducts[index] = newName;
    }

    private async Task SaveNewProductAsync(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return;

        // Persist via service
        var productDto = new ProductDetailDTO { Name = name, IsActive = true };
        await ProductService.CreateAsync(productDto);

        // Update lists
        AllProducts.Add(productDto);
        UnsavedProducts.Remove(name);
        SelectedProducts.Add(name);
        await SelectedProductsChanged.InvokeAsync(SelectedProducts);
    }
}