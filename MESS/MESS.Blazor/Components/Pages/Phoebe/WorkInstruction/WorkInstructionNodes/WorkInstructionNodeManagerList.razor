@using MESS.Blazor.Components.Pages.Phoebe.WorkInstruction.WorkInstructionNodes.SortableList
@using MESS.Data.Models
@using MESS.Services.DTOs.WorkInstructions.Nodes.Form
@using MESS.Services.DTOs.WorkInstructions.Nodes.PartNodes.Form
@using MESS.Services.DTOs.WorkInstructions.Nodes.StepNodes.Form

<SortableList T="WorkInstructionNodeFormDTO"
              Items="WorkInstructionNodes"
              Handle=".drag-handle"
              OnUpdate="OnItemsChanged"
              Disabled="IsMinimalEditingMode"
              Context="node">
    <SortableItemTemplate>
        @NodeTemplate(node)
    </SortableItemTemplate>
</SortableList>


@code {
    /// <summary>
    /// Gets or sets the list of work instruction nodes to render and manage in the sortable list.
    /// </summary>
    [Parameter, EditorRequired]
    public required List<WorkInstructionNodeFormDTO> WorkInstructionNodes { get; set; }

    /// <summary>
    /// Event callback that is triggered when *any* of the steps in this list has been changed.
    /// </summary>
    [Parameter]
    public EventCallback<WorkInstructionNodeFormDTO?> OnChanged { get; set; }

    /// <summary>
    /// Event callback triggered when a node is removed from the list.
    /// </summary>
    [Parameter]
    public EventCallback<WorkInstructionNodeFormDTO> OnNodeRemoved { get; set; }

    /// <summary>
    /// Event callback that is triggered when a new node needs to be created at an index.
    /// </summary>
    [Parameter]
    public EventCallback<(string, int)> OnNewNodeAt { get; set; }

    /// <summary>
    /// When <c>true</c>, drag-and-drop reordering is disabled and structural node actions are
    /// hidden/disabled. This follows Minimal Editing Mode for instructions with production logs.
    /// </summary>
    [Parameter]
    public bool IsMinimalEditingMode { get; set; }

    private Dictionary<Guid, BlazoredTextEditor> EditorRefs { get; set; } = new();
    private Dictionary<Guid, string> ActiveFields { get; set; } = new();

    private RenderFragment<WorkInstructionNodeFormDTO> NodeTemplate => (node) =>
        @<div id="node-@node.Position">
            <div class="d-flex mb-3 border rounded disable-highlight shadow-sm">
                @if (!IsMinimalEditingMode)
                {
                    <div class="d-flex align-items-center drag-handle me-2">
                        <i class="bi bi-grip-vertical h3"/>
                        <div class="vr me-2"/>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center me-2 px-2 text-muted" title="Reordering disabled — production logs exist.">
                        <i class="bi bi-grip-vertical h3 opacity-25"/>
                        <div class="vr me-2"/>
                    </div>
                }
                <div class="flex-grow-1 my-1">
                    @switch (node)
                    {
                        case PartNodeFormDTO partNode:
                            <PartNodeView PartNode="partNode"
                                          IsMinimalEditingMode="IsMinimalEditingMode"
                                          OnNodeAction="HandleNodeAction"
                                          OnChanged="() => OnChanged.InvokeAsync(node)"/>
                            break;

                        case StepNodeFormDTO stepNode:
                            <StepNodeView Step="stepNode"
                                          EditorRefs="EditorRefs"
                                          ActiveFields="ActiveFields"
                                          OnAction="HandleNodeAction"
                                          OnChanged="() => OnChanged.InvokeAsync(node)"/>
                            break;

                        default:
                            <div>Unknown node type: @node.NodeType</div>
                            break;
                    }
                </div>
            </div>
        </div>;

    private async Task OnItemsChanged((int oldIndex, int newIndex) indices)
    {
        if (IsMinimalEditingMode) return;

        var (oldIndex, newIndex) = indices;
        if (oldIndex == newIndex) return;

        await SaveAllEditorsContentAsync();

        var itemToMove = WorkInstructionNodes[oldIndex];
        WorkInstructionNodes.RemoveAt(oldIndex);

        if (newIndex < WorkInstructionNodes.Count)
            WorkInstructionNodes.Insert(newIndex, itemToMove);
        else
            WorkInstructionNodes.Add(itemToMove);

        if (OnChanged.HasDelegate)
            await OnChanged.InvokeAsync();
    }

    private async Task HandleNodeAction((WorkInstructionNodeFormDTO node, string action) actionTuple)
    {
        var (node, action) = actionTuple;
        var index = WorkInstructionNodes.IndexOf(node);
        if (index == -1) return;

        if (action is ("insertBefore" or "insertAfter"))
        {
            if (IsMinimalEditingMode) return;
            if (OnNewNodeAt.HasDelegate)
            {
                switch (action)
                {
                    case "insertBefore":
                        await OnNewNodeAt.InvokeAsync((node is PartNodeFormDTO ? "part" : "step", index));
                        break;
                    case "insertAfter":
                        await OnNewNodeAt.InvokeAsync((node is PartNodeFormDTO ? "part" : "step", index + 1));
                        break;
                }
            }
        }
        else
        {
            await SaveAllEditorsContentAsync();

            WorkInstructionNodes.Remove(node);

            switch (action)
            {
                case "up":
                    if (!IsMinimalEditingMode) WorkInstructionNodes.Insert(Math.Max(0, index - 1), node);
                    else WorkInstructionNodes.Insert(index, node);
                    break;
                case "down":
                    if (!IsMinimalEditingMode) WorkInstructionNodes.Insert(Math.Min(WorkInstructionNodes.Count, index + 1), node);
                    else WorkInstructionNodes.Insert(index, node);
                    break;
                case "top":
                    if (!IsMinimalEditingMode) WorkInstructionNodes.Insert(0, node);
                    else WorkInstructionNodes.Insert(index, node);
                    break;
                case "bottom":
                    if (!IsMinimalEditingMode) WorkInstructionNodes.Add(node);
                    else WorkInstructionNodes.Insert(index, node);
                    break;
                case "remove":
                    // already removed above — only proceed if not in minimal mode
                    if (!IsMinimalEditingMode && OnNodeRemoved.HasDelegate)
                        await OnNodeRemoved.InvokeAsync(node);
                    else
                        WorkInstructionNodes.Insert(index, node); // put it back
                    break;
            }

            if (OnChanged.HasDelegate)
                await OnChanged.InvokeAsync(node);
        }
    }

    /// <summary>
    /// Saves all in-progress Quill editor content back to the DTO model.
    /// </summary>
    public async Task SaveAllEditorsContentAsync()
    {
        foreach (var kvp in EditorRefs)
        {
            var stepClientId = kvp.Key;
            var editor = kvp.Value;
            var currentHtml = await editor.GetHTML();
            var node = WorkInstructionNodes.FirstOrDefault(n => n is StepNodeFormDTO s && s.ClientId == stepClientId);
            if (node is StepNodeFormDTO step)
            {
                if (ActiveFields.TryGetValue(stepClientId, out var field) && field == "Body")
                    step.DetailedBody = currentHtml;
                else
                    step.Body = currentHtml;
            }
        }
    }
}
