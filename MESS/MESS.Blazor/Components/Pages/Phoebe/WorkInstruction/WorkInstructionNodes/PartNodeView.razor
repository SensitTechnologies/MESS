@using MESS.Data.Models
@using MESS.Services.DTOs.WorkInstructions.Nodes.Form
@using MESS.Services.DTOs.WorkInstructions.Nodes.PartNodes.Form
@inherits ComponentBase

<div class="d-flex align-items-start justify-content-between flex-wrap">
    <div class="row flex-grow-1 g-2">
        <div class="col-auto">
            <div class="border rounded ps-2 py-2 h-100 d-flex align-items-center gap-2 shadow-sm" style="padding-right: 0.5rem;">

                @if (IsMinimalEditingMode)
                {
                    <small class="text-muted fst-italic">Read-only — part associations cannot change while production logs exist.</small>
                }

                <!-- Part Name -->
                <div class="d-flex flex-column">
                    <label class="form-label mb-1">Part Name</label>
                    <input type="text"
                           class="form-control form-control-sm"
                           @bind="PartNode!.Name"
                           @bind:event="oninput"
                           @bind:after="NotifyChangedAsync"
                           readonly="@IsMinimalEditingMode" />
                </div>

                <!-- Part Number -->
                <div class="d-flex flex-column">
                    <label class="form-label mb-1">Part Number</label>
                    <input type="text"
                           class="form-control form-control-sm"
                           @bind="PartNode!.Number"
                           @bind:event="oninput"
                           @bind:after="NotifyChangedAsync"
                           readonly="@IsMinimalEditingMode" />
                </div>

            </div>
        </div>
    </div>

    <NodeActionMenu OnAction="HandleNodeAction" IsMinimalEditingMode="IsMinimalEditingMode" />
</div>

@code {
    [Parameter]
    public EventCallback<(WorkInstructionNodeFormDTO node, string action)> OnNodeAction { get; set; }

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [Parameter, EditorRequired]
    public PartNodeFormDTO? PartNode { get; set; }

    /// <summary>
    /// When <c>true</c>, all part-node fields are rendered read-only and the action menu
    /// shows only disabled items. Follows the minimal editing mode constraint.
    /// </summary>
    [Parameter]
    public bool IsMinimalEditingMode { get; set; }

    private async Task HandleNodeAction(string action)
    {
        if (PartNode is null)
            return;

        if (OnNodeAction.HasDelegate)
            await OnNodeAction.InvokeAsync((PartNode, action));

        await NotifyChangedAsync();
    }

    private async Task NotifyChangedAsync()
    {
        if (OnChanged.HasDelegate)
            await OnChanged.InvokeAsync();
    }
}
