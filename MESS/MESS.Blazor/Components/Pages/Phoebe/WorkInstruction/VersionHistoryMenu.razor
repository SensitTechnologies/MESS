@using MESS.Services.DTOs.WorkInstructions.Version

<div class="version-history-container">
    @if (IsOpen)
    {
        <div class="sidebar-backdrop" @onclick="OnToggleClicked"></div>
    }

    <div class="sidebar-panel @(IsOpen ? "open" : "closed")">
    <!-- Sidebar Header -->
    <div class="sidebar-header d-flex justify-content-between align-items-center mb-3">
        <h5>Version History</h5>
        <button class="btn-close" @onclick="OnToggleClicked" aria-label="Close sidebar" />
    </div>

    @* Loading Spinner *@
    @if (IsLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status" aria-hidden="true"></div>
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    @* No Versions Message *@
    else if (Versions == null || !Versions.Any())
    {
        <p class="text-muted">No versions available for this work instruction.</p>
    }
    @* Versions List *@
    else
    {
        <div class="version-list">
            @foreach (var version in Versions)
            {
                var isCurrent = CurrentVersionId.HasValue && version.Id == CurrentVersionId.Value;

                <div @key="version.Id"
                     class="version-item border rounded p-2 mb-2 @(isCurrent ? "bg-light" : "")">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>
                                @(isCurrent ? "Current Version: " : "Version: ")
                                @(string.IsNullOrWhiteSpace(version.Version) ? "N/A" : version.Version)
                            </strong>

                            <div class="text-muted small">
                                @version.LastModifiedOn.ToLocalTime().ToString("g")
                            </div>

                            <div class="text-muted small">
                                @version.Title
                            </div>

                            @if (version.HasProductionLogs)
                            {
                                <div class="text-warning small">
                                    <i class="bi bi-journal-text me-1"></i>Has production logs
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            @if (isCurrent)
                            {
                                <button class="btn btn-sm btn-secondary" disabled>
                                    Loaded
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success"
                                        aria-label="Restore version @version.Version"
                                        @onclick="() => OnRestoreClicked(version.Id)">
                                    Restore
                                </button>

                                @if (version.HasProductionLogs && !IsAdministrator)
                                {
                                    <button class="btn btn-sm btn-danger"
                                            disabled
                                            title="This version has associated production logs — contact an Administrator to delete.">
                                        Delete
                                    </button>
                                }
                                else if (version.HasProductionLogs && IsAdministrator)
                                {
                                    <button class="btn btn-sm btn-danger"
                                            aria-label="Delete version @version.Version (has logs)"
                                            title="Delete version — requires export of associated logs"
                                            @onclick="() => OnDeleteWithLogsClicked(version.Id)">
                                        Delete
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-danger"
                                            aria-label="Delete version @version.Version"
                                            @onclick="() => OnDeleteClicked(version.Id)">
                                        Delete
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
</div>


@code {
    /// <summary>
    /// Gets or sets a value indicating whether the version history sidebar is open or closed.
    /// </summary>
    [Parameter] public bool IsOpen { get; set; } = false;

    /// <summary>
    /// Event callback triggered when the user clicks the close button or otherwise toggles the sidebar's visibility.
    /// </summary>
    [Parameter] public EventCallback OnToggle { get; set; }

    /// <summary>
    /// The id of the current (active) work instruction being edited.
    /// </summary>
    [Parameter]
    public int? CurrentVersionId { get; set; }

    /// <summary>
    /// The list of all historical versions of the current work instruction.
    /// </summary>
    [Parameter]
    public List<WorkInstructionVersionDTO>? Versions { get; set; }

    /// <summary>
    /// Whether the parent is still loading them.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; } = false;

    /// <summary>
    /// True when the current user holds the Administrator role.
    /// Controls whether the delete button is shown or disabled for versions with production logs.
    /// </summary>
    [Parameter]
    public bool IsAdministrator { get; set; }

    /// <summary>
    /// Event callback to restore a given version by ID.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnRestore { get; set; }

    /// <summary>
    /// Event callback to delete a given version by ID (no associated production logs).
    /// </summary>
    [Parameter]
    public EventCallback<int> OnDelete { get; set; }

    /// <summary>
    /// Event callback raised when an Administrator tries to delete a version that has production logs.
    /// The parent is responsible for showing the export-before-delete flow.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnDeleteWithLogs { get; set; }

    private async Task OnToggleClicked()
    {
        if (OnToggle.HasDelegate)
            await OnToggle.InvokeAsync(null);
    }

    private async Task OnRestoreClicked(int versionId)
    {
        if (OnRestore.HasDelegate)
            await OnRestore.InvokeAsync(versionId);
    }

    private async Task OnDeleteClicked(int versionId)
    {
        if (OnDelete.HasDelegate)
            await OnDelete.InvokeAsync(versionId);
    }

    private async Task OnDeleteWithLogsClicked(int versionId)
    {
        if (OnDeleteWithLogs.HasDelegate)
            await OnDeleteWithLogs.InvokeAsync(versionId);
    }
}
