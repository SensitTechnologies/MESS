@using MESS.Data.Models
@using MESS.Services.Product
@using MESS.Services.WorkInstruction
@inject IWorkInstructionEditorService EditorService
@inject IToastService ToastService
@inject IProductService ProductService
@using Microsoft.AspNetCore.Components

<div class="toast-container position-fixed top-50 start-50 translate-middle p-3 @(IsVisible ? "d-block" : "d-none")" style="z-index: 1055;">
    <div class="toast show custom-toast-body @darkModeClass" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header custom-toast-header">
            <span class="me-auto">@HeaderText</span>
        </div>

        <div class="toast-body">
            <div class="mb-3">
                @if (WorkInstruction != null && AllProducts != null)
                {
                    <ProductSelector WorkInstruction="WorkInstruction"
                                     AllProducts="AllProducts"
                                     OnProductsChanged="OnProductsChangedInternal" />
                }
                else
                {
                    <div class="text-muted">Loading products or work instruction...</div>
                }
            </div>

            <div class="mb-3">
                <label for="nameInput" class="form-label">Name:</label>
                <textarea id="nameInput"
                          class="form-control"
                          placeholder="Enter name here..."
                          rows="1"
                          @bind="WorkInstructionTitle"></textarea>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-primary" @onclick="HandleSave">@PrimaryButtonText</button>
                <button type="button" class="btn btn-secondary" @onclick="Close">Cancel</button>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Indicates whether the popup is currently visible.
    /// </summary>
    [Parameter] public bool IsVisible { get; set; }

    /// <summary>
    /// Callback triggered when the visibility of the popup changes.
    /// </summary>
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>
    /// Header text shown in the toast title bar.
    /// </summary>
    [Parameter] public string? HeaderText { get; set; } = "Edit Work Instruction";

    /// <summary>
    /// Text label for the primary button (e.g. "Save", "Save As").
    /// </summary>
    [Parameter] public string PrimaryButtonText { get; set; } = "Save";

    /// <summary>
    /// Indicates whether dark mode styling should be applied.
    /// </summary>
    [Parameter] public bool IsDarkMode { get; set; }

    /// <summary>
    /// Event callback invoked when the Save button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnSave { get; set; }

    /// <summary>
    /// Event callback invoked when the "Save As" operation is requested.
    /// </summary>
    [Parameter] public EventCallback OnSaveAs { get; set; }

    /// <summary>
    /// The current work instruction being edited.
    /// </summary>
    [Parameter] public WorkInstruction? WorkInstruction { get; set; }

    /// <summary>
    /// List of all available products for selection.
    /// </summary>
    [Parameter] public List<Product>? AllProducts { get; set; }

    /// <summary>
    /// Callback triggered when the selected products are modified.
    /// </summary>
    [Parameter] public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Returns the dark mode CSS class if dark mode is enabled.
    /// </summary>
    private string darkModeClass => IsDarkMode ? "dark-mode" : string.Empty;

    /// <summary>
    /// Two-way binding property for the work instruction title input field.
    /// </summary>
    private string WorkInstructionTitle
    {
        get => WorkInstruction?.Title ?? string.Empty;
        set
        {
            if (WorkInstruction != null && WorkInstruction.Title != value)
            {
                WorkInstruction.Title = value;
                EditorService.MarkDirty();
            }
        }
    }

    /// <summary>
    /// Handles the updated product list coming from the ProductSelector.
    /// Updates the WorkInstruction and refreshes product list.
    /// </summary>
    /// <param name="updatedProducts">New list of selected products.</param>
    private async Task OnProductsChangedInternal(List<Product> updatedProducts)
    {
        if (WorkInstruction != null)
        {
            WorkInstruction.Products = updatedProducts;
            EditorService.MarkDirty();
        }

        if (OnProductsChanged.HasDelegate)
            await OnProductsChanged.InvokeAsync(updatedProducts);

        if (ProductService != null)
        {
            var refreshedProducts = (await ProductService.GetAllAsync()).ToList();
            AllProducts?.Clear();
            AllProducts?.AddRange(refreshedProducts);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Closes the popup and updates the visibility binding.
    /// </summary>
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    /// <summary>
    /// Handles saving logic for both regular Save and "Save As" operations.
    /// Performs validation and triggers the relevant callbacks.
    /// </summary>
    private async Task HandleSave()
    {
        if (WorkInstruction == null)
        {
            ToastService.ShowError("No Work Instruction loaded.");
            return;
        }

        string trimmedTitle = WorkInstruction.Title?.Trim() ?? "";
        string trimmedVersion = WorkInstruction.Version?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            ToastService.ShowError("Title is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(trimmedVersion))
        {
            ToastService.ShowError("Version is required.");
            return;
        }

        WorkInstruction.Title = trimmedTitle;
        WorkInstruction.Version = trimmedVersion;

        try
        {
            bool success;

            if (PrimaryButtonText.Equals("Save As", StringComparison.OrdinalIgnoreCase))
            {
                if (OnSaveAs.HasDelegate)
                    await OnSaveAs.InvokeAsync();

                success = await EditorService.SaveAsync();
            }
            else
            {
                if (OnSave.HasDelegate)
                    await OnSave.InvokeAsync();

                success = await EditorService.SaveAsync();
            }

            if (!success)
            {
                ToastService.ShowError("Failed to save Work Instruction. Ensure Title and Version are unique.");
                return;
            }

            ToastService.ShowSuccess("Work Instruction saved successfully.");
            await Close();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("An error occurred while saving the Work Instruction.");
            Console.Error.WriteLine(ex);
        }
    }
}
