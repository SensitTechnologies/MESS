@using MESS.Data.Models
@inject MESS.Services.Product.IProductService ProductService

@{
    var showClass = IsVisible ? "win-popup-show" : "win-popup-hide";
    var darkModeClass = IsDarkMode ? "dark-mode" : "";
}

<div class="win-popup @showClass @darkModeClass" role="dialog" aria-modal="true" aria-labelledby="popupTitle" aria-describedby="popupBody">
    <div class="win-titlebar">
        <span id="popupTitle" class="win-title-text">@HeaderText</span>
    </div>

    <div id="popupBody" class="win-body">
        <ProductSelector AllProducts="AllProducts"
                         OnProductsChanged="OnProductsChanged"
                         OnProductAdded="HandleProductAdded" />
        <hr />

        <div class="resizable-textarea-container mt-3">
            <label for="nameInput" class="form-label">Name:</label>
            <textarea id="nameInput"
                      class="form-control transparent-textarea"
                      placeholder="Enter name here..."
                      rows="1"
                      @bind="WorkInstructionTitle"></textarea>
        </div>
    </div>

    <div class="win-footer">
        <button class="win-btn-cancel" @onclick="StartNewInstruction">New</button>
        <button class="win-btn-cancel" @onclick="Close">Cancel</button>
    </div>
</div>

@code {
    /// <summary>
    /// Gets or sets whether the popup is visible.
    /// </summary>
    [Parameter] public bool IsVisible { get; set; }

    /// <summary>
    /// Event callback triggered when the popup's visibility changes.
    /// </summary>
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>
    /// The header text shown at the top of the popup.
    /// </summary>
    [Parameter] public string? HeaderText { get; set; }

    /// <summary>
    /// Indicates whether dark mode is active for the popup UI.
    /// </summary>
    [Parameter] public bool IsDarkMode { get; set; }

    /// <summary>
    /// A required list of all available products for selection.
    /// </summary>
    [Parameter] public required List<Product> AllProducts { get; set; }

    /// <summary>
    /// Invoked when the product selection changes.
    /// </summary>
    [Parameter] public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Invoked after a product is saved (created or renamed).
    /// </summary>
    [Parameter] public EventCallback<Product> OnProductSaved { get; set; }

    /// <summary>
    /// Invoked after a work instruction is duplicated or saved.
    /// </summary>
    [Parameter] public EventCallback<WorkInstruction> OnWorkInstructionDuplicated { get; set; }

    /// <summary>
    /// Event callback triggered when the user starts a new instruction from the popup.
    /// </summary>
    [Parameter] public EventCallback OnStartNewInstruction { get; set; }

    /// <summary>
    /// Gets or sets the title of the work instruction entered by the user.
    /// This value is bound to the name input field in the UI.
    /// </summary>
    private string WorkInstructionTitle { get; set; } = string.Empty;

    /// <summary>
    /// Shows the popup with the specified body and header text.
    /// </summary>
    /// <param name="bodyText">The content body text (unused).</param>
    /// <param name="headerText">The header text to display.</param>
    public void Show(string bodyText, string headerText = "")
    {
        HeaderText = headerText;
        IsVisible = true;
        StateHasChanged();
    }

    /// <summary>
    /// Closes the popup and clears its header.
    /// </summary>
    private void Close()
    {
        HeaderText = string.Empty;
        IsVisible = false;
        StateHasChanged();
    }

    /// <summary>
    /// Invokes the start new instruction callback.
    /// </summary>
    private async Task StartNewInstruction()
    {
        if (OnStartNewInstruction.HasDelegate)
        {
            await OnStartNewInstruction.InvokeAsync();
        }
    }

    /// <summary>
    /// Handles renaming a product and updates it via the product service.
    /// </summary>
    /// <param name="args">Tuple containing the product and the new name.</param>
    private async Task HandleProductNameChanged((Product product, string newName) args)
    {
        try
        {
            args.product.Name = args.newName;
            await ProductService.UpdateProductAsync(args.product);

            if (OnProductSaved.HasDelegate)
                await OnProductSaved.InvokeAsync(args.product);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving product name: {ex.Message}");
        }
    }

    /// <summary>
    /// Handles product creation and notifies the UI via callback.
    /// </summary>
    /// <param name="newProduct">The newly created product to persist.</param>
    private async Task HandleProductAdded(Product newProduct)
    {
        try
        {
            await ProductService.CreateAsync(newProduct);

            if (OnProductSaved.HasDelegate)
                await OnProductSaved.InvokeAsync(newProduct);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error adding new product: {ex.Message}");
        }
    }
}
