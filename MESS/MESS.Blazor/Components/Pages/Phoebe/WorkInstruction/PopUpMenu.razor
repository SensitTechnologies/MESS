@using MESS.Data.Models
@using MESS.Services.Product
@using MESS.Blazor.Components.Pages.Phoebe.WorkInstruction
@using Microsoft.AspNetCore.Components

@if (IsVisible)
{
    <!-- Removed the backdrop to avoid darkening the background -->
    <div class="win-popup @darkModeClass" role="dialog" aria-modal="true" aria-labelledby="popupTitle" aria-describedby="popupBody">
        <div class="win-titlebar">
            <span id="popupTitle" class="win-title-text">@HeaderText</span>
        </div>

        <div id="popupBody" class="win-body">
            <div class="product-selector-wrapper">
                @if (WorkInstruction != null && AllProducts != null)
                {
                    <ProductSelector WorkInstruction="WorkInstruction"
                                     AllProducts="AllProducts"
                                     OnProductsChanged="OnProductsChanged" />
                }
                else
                {
                    <div class="text-muted">Loading products or work instruction...</div>
                }
            </div>

            <div class="textarea-container">
                <label for="nameInput" class="form-label">Name:</label>
                <textarea id="nameInput"
                          class="form-control transparent-textarea"
                          placeholder="Enter name here..."
                          rows="1"
                          @bind="WorkInstructionTitle"></textarea>
            </div>
        </div>

        <div class="win-footer">
            <button class="win-btn-primary" @onclick="HandleSave">@PrimaryButtonText</button>
            <button class="win-btn-cancel" @onclick="Close">Cancel</button>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets a value indicating whether the popup is currently visible.
    /// Parent controls visibility by setting this parameter.
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }

    /// <summary>
    /// Event callback invoked when the visibility of the popup changes.
    /// Used for two-way binding to close the dialog externally.
    /// </summary>
    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>
    /// Gets or sets the header text to display in the popup's title bar.
    /// Controlled by parent component.
    /// </summary>
    [Parameter]
    public string? HeaderText { get; set; } = "Edit Work Instruction";

    /// <summary>
    /// Gets or sets the text label for the primary action button (e.g., Save, Create).
    /// Controlled by parent component.
    /// </summary>
    [Parameter]
    public string PrimaryButtonText { get; set; } = "Save";

    /// <summary>
    /// Gets or sets a value indicating whether dark mode styles should be applied.
    /// </summary>
    [Parameter]
    public bool IsDarkMode { get; set; }

    /// <summary>
    /// Callback invoked when the Save button is clicked.
    /// Typically triggers persistence logic in the parent component.
    /// </summary>
    [Parameter]
    public EventCallback OnSave { get; set; }

    /// <summary>
    /// Callback invoked for Save As logic if implemented externally.
    /// </summary>
    [Parameter]
    public EventCallback OnSaveAs { get; set; }

    /// <summary>
    /// Gets or sets the current <see cref="WorkInstruction"/> being edited.
    /// This object is bound to the UI input fields.
    /// </summary>
    [Parameter]
    public WorkInstruction? WorkInstruction { get; set; }

    /// <summary>
    /// Gets or sets the full list of available <see cref="Product"/> options.
    /// </summary>
    [Parameter]
    public List<Product>? AllProducts { get; set; }

    /// <summary>
    /// Callback triggered when the set of selected products changes.
    /// Invoked by the child <c>ProductSelector</c> component.
    /// </summary>
    [Parameter]
    public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Gets the CSS class used to apply dark mode styling.
    /// </summary>
    private string darkModeClass => IsDarkMode ? "dark-mode" : string.Empty;

    /// <summary>
    /// Gets or sets the editable title of the current <see cref="WorkInstruction"/>.
    /// Binds the textarea input to the instruction title field.
    /// </summary>
    private string WorkInstructionTitle
    {
        get => WorkInstruction?.Title ?? string.Empty;
        set
        {
            if (WorkInstruction != null && WorkInstruction.Title != value)
            {
                WorkInstruction.Title = value;
            }
        }
    }

    /// <summary>
    /// Closes the popup and notifies the parent component by invoking <see cref="IsVisibleChanged"/>.
    /// </summary>
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    /// <summary>
    /// Handles the Save button logic.
    /// Ensures a valid OriginalId is set, invokes save logic from parent, and then closes the popup.
    /// </summary>
    private async Task HandleSave()
    {
        if (WorkInstruction != null)
        {
            // Ensure OriginalId is set for version tracking
            if (WorkInstruction.OriginalId == 0)
            {
                WorkInstruction.OriginalId = WorkInstruction.Id != 0 ? WorkInstruction.Id : -1;
            }
        }

        if (OnSave.HasDelegate)
        {
            await OnSave.InvokeAsync(null);
        }

        await Close();
    }
}
