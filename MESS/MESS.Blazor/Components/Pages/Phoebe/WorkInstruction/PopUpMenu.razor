@using MESS.Data.Models
@using MESS.Services.Product
@using MESS.Services.WorkInstruction
@inject IWorkInstructionEditorService EditorService
@inject IToastService ToastService
@inject IProductService ProductService
@using Microsoft.AspNetCore.Components

@if (IsVisible)
{
    <div class="win-popup @darkModeClass" role="dialog" aria-modal="true" aria-labelledby="popupTitle" aria-describedby="popupBody">
        <div class="win-titlebar">
            <span id="popupTitle" class="win-title-text">@HeaderText</span>
        </div>

        <div id="popupBody" class="win-body">
            <div class="product-selector-wrapper">
                @if (WorkInstruction != null && AllProducts != null)
                {
                    <ProductSelector WorkInstruction="WorkInstruction"
                                     AllProducts="AllProducts"
                                     OnProductsChanged="OnProductsChangedInternal" />
                }
                else
                {
                    <div class="text-muted">Loading products or work instruction...</div>
                }
            </div>

            <div class="textarea-container">
                <label for="nameInput" class="form-label">Name:</label>
                <textarea id="nameInput"
                          class="form-control transparent-textarea"
                          placeholder="Enter name here..."
                          rows="1"
                          @bind="WorkInstructionTitle"></textarea>
            </div>
        </div>

        <div class="win-footer">
            <button class="win-btn-primary" @onclick="HandleSave">@PrimaryButtonText</button>
            <button class="win-btn-cancel" @onclick="Close">Cancel</button>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets a value indicating whether the popup is currently visible.
    /// Controlled by the parent component.
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }

    /// <summary>
    /// Event callback invoked when the visibility of the popup changes.
    /// Enables two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>
    /// Gets or sets the header text displayed in the popup title bar.
    /// </summary>
    [Parameter]
    public string? HeaderText { get; set; } = "Edit Work Instruction";

    /// <summary>
    /// Gets or sets the label text for the primary action button (e.g., "Save", "Create").
    /// </summary>
    [Parameter]
    public string PrimaryButtonText { get; set; } = "Save";

    /// <summary>
    /// Gets or sets a value indicating whether dark mode styles are applied.
    /// </summary>
    [Parameter]
    public bool IsDarkMode { get; set; }

    /// <summary>
    /// Callback invoked when the Save button is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnSave { get; set; }

    /// <summary>
    /// Callback invoked when the Save As operation is requested.
    /// </summary>
    [Parameter]
    public EventCallback OnSaveAs { get; set; }

    /// <summary>
    /// Gets or sets the current WorkInstruction being edited.
    /// Bound to the title input and product selector.
    /// </summary>
    [Parameter]
    public WorkInstruction? WorkInstruction { get; set; }

    /// <summary>
    /// Gets or sets the list of all products available for selection.
    /// Used by the <see cref="ProductSelector"/> child component.
    /// </summary>
    [Parameter]
    public List<Product>? AllProducts { get; set; }

    /// <summary>
    /// Event callback triggered when the product selection changes inside the popup.
    /// Used to propagate changes to the parent component.
    /// </summary>
    [Parameter]
    public EventCallback<List<Product>> OnProductsChanged { get; set; }

    /// <summary>
    /// Returns the CSS class string for enabling dark mode.
    /// </summary>
    private string darkModeClass => IsDarkMode ? "dark-mode" : string.Empty;

    /// <summary>
    /// Gets or sets the editable title of the current WorkInstruction.
    /// Binds the textarea to this property and updates the EditorService state.
    /// </summary>
    private string WorkInstructionTitle
    {
        get => WorkInstruction?.Title ?? string.Empty;
        set
        {
            if (WorkInstruction != null && WorkInstruction.Title != value)
            {
                WorkInstruction.Title = value;
                EditorService.MarkDirty();
            }
        }
    }

    /// <summary>
    /// Handles product selection updates from the child <see cref="ProductSelector"/> component.
    /// Updates the current WorkInstruction products and marks the editor as dirty.
    /// Refreshes the full product list from the database.
    /// </summary>
    /// <param name="updatedProducts">The list of newly selected products.</param>
    private async Task OnProductsChangedInternal(List<Product> updatedProducts)
    {
        if (WorkInstruction != null)
        {
            WorkInstruction.Products = updatedProducts;
            EditorService.MarkDirty();
        }

        if (OnProductsChanged.HasDelegate)
            await OnProductsChanged.InvokeAsync(updatedProducts);

        if (ProductService != null)
        {
            var refreshedProducts = (await ProductService.GetAllAsync()).ToList();
            AllProducts?.Clear();
            AllProducts?.AddRange(refreshedProducts);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Closes the popup and notifies the parent to update the visibility state.
    /// </summary>
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    /// <summary>
    /// Handles the primary save button logic.
    /// Decides between normal save and save as based on <see cref="PrimaryButtonText"/>,
    /// calls callbacks, saves through EditorService, and handles error display.
    /// </summary>
    private async Task HandleSave()
    {
        if (WorkInstruction == null)
        {
            ToastService.ShowError("No Work Instruction loaded.");
            return;
        }

        string trimmedTitle = WorkInstruction.Title?.Trim() ?? "";
        string trimmedVersion = WorkInstruction.Version?.Trim() ?? "";

        if (string.IsNullOrWhiteSpace(trimmedTitle))
        {
            ToastService.ShowError("Title is required.");
            return;
        }

        if (string.IsNullOrWhiteSpace(trimmedVersion))
        {
            ToastService.ShowError("Version is required.");
            return;
        }

        // Apply trimmed values back to the work instruction
        WorkInstruction.Title = trimmedTitle;
        WorkInstruction.Version = trimmedVersion;

        try
        {
            bool success;

            if (PrimaryButtonText.Equals("Save As", StringComparison.OrdinalIgnoreCase))
            {
                if (OnSaveAs.HasDelegate)
                    await OnSaveAs.InvokeAsync();

                success = await EditorService.SaveAsync();
            }
            else
            {
                if (OnSave.HasDelegate)
                    await OnSave.InvokeAsync();

                success = await EditorService.SaveAsync();
            }

            if (!success)
            {
                ToastService.ShowError("Failed to save Work Instruction. Ensure the Title and Version are unique.");
                return;
            }

            ToastService.ShowSuccess("Work Instruction saved successfully.");
            await Close();
        }
        catch (Exception ex)
        {
            ToastService.ShowError("An error occurred while saving the Work Instruction.");
            Console.Error.WriteLine(ex);
        }
    }
}
