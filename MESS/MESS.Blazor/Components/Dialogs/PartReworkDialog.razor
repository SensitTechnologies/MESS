@using MESS.Services.CRUD.PartTraceability
@using MESS.Services.UI.PartTraceability
@using MESS.Services.UI.ProductionLogEvent
@using Serilog

@inject IProductionLogEventService ProductionLogEventService
@inject IPartTraceabilityReworkService PartTraceabilityReworkService
@inject IPartTraceabilityStateService PartTraceabilityStateService

<div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Scan Parts to Rework</h5>
                <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (!IsProcessing)
                {
                    <div class="d-flex flex-wrap gap-2 justify-content-around align-content-center">
                        @for (var i = 0; i < BatchSize; i++)
                        {
                            var index = i;
                            var inputId = $"tagCodeInput_{i}";
                            <div class="form-floating flex-grow-1">
                                <InputText id="@inputId"
                                           class="form-control tall-input text-lightweight"
                                           placeholder="Scan Tag"
                                           @bind-Value="TagCodes[index]" />
                                <label for="@inputId" class="form-label subtle-label">#@(i + 1)</label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center my-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <span class="ms-2">Processing...</span>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="ConfirmAsync" disabled="@IsProcessing">
                    Load Parts
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@IsProcessing">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WorkInstructionId { get; set; }
    [Parameter] public int BatchSize { get; set; } = 1;
    [Parameter] public EventCallback OnClose { get; set; }

    private bool IsProcessing { get; set; } = false;
    
    private List<string> TagCodes { get; set; } = new();

    protected override void OnInitialized()
    {
        // Initialize with empty strings
        TagCodes = Enumerable.Repeat(string.Empty, BatchSize).ToList();
    }

    private async Task ConfirmAsync()
    {
        IsProcessing = true;
        StateHasChanged(); // refresh spinner immediately

        try
        {
            var logs = ProductionLogEventService.CurrentProductionLogs.ToList();
            if (logs.Count == 0)
                return;

            if (TagCodes.Count != logs.Count)
                throw new InvalidOperationException("Number of tag code inputs must match the number of active logs.");

            var snapshots = new List<PartTraceabilitySnapshot>();

            for (int i = 0; i < logs.Count; i++)
            {
                var log = logs[i];
                var tagCode = TagCodes[i]?.Trim();

                if (string.IsNullOrEmpty(tagCode))
                    continue;

                var result = await PartTraceabilityReworkService.BuildSnapshotsFromTagCodesAsync(
                    new List<string> { tagCode },
                    WorkInstructionId);

                snapshots.AddRange(result);
            }

            PartTraceabilityStateService.LoadSnapshots(snapshots);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Failed to load part snapshots from tag codes.");
            throw;
        }
        finally
        {
            IsProcessing = false;
            StateHasChanged(); // update UI after processing
        }

        await CloseModal();
    }

    private async Task CloseModal()
    {
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }
}